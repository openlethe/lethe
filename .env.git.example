# Local-only Lethe Memory Git service.
# Copy to .env.git and keep it out of version control.

# Generate each value with: openssl rand -hex 32
LETHE_API_KEY=replace-with-local-lethe-git-api-key
CHARON_MERGE_HMAC_KEY=replace-with-shared-charon-hmac-key

# Fresh database; never point this at the OpenLethe/OpenClaw data directory.
LETHE_GIT_DATA_DIR=./lethe-git-data
