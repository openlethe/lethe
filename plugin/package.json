{
  "name": "@mentholmike/lethe",
  "version": "0.4.0",
  "description": "Lethe — persistent memory layer for AI agents. OpenClaw plugin.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "openclaw.plugin.json",
    "SKILL.md"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": "2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1"
    },
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "npm run build && node --test dist/**/*.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "^0.70.0",
    "openclaw": ">=2026.7.1"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.70.0",
    "@types/node": "^20.0.0",
    "openclaw": "2026.7.1",
    "typescript": "^5.4.0",
    "tsc-alias": "^1.8.0"
  }
}
