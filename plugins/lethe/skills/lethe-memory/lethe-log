#!/bin/bash
# lethe-log — Low-friction event recording for Lethe memory layer
# Usage: lethe-log <record|log|flag|task> <message> [options]
#
# Requires: curl, jq
# API: http://localhost:18483 (LETHE_API env var overrides)

set -e

API="${LETHE_API:-http://localhost:18483}"

# SESSION_KEY: injected by Lethe plugin at runtime
# FALLBACK_SESSION_KEY: used when SESSION_KEY is empty (e.g. Discord channel session)
FALLBACK_SID="86e09dc7-7ed9-4776-9b0e-d8c7678a0357"
SESSION_ID="${SESSION_KEY:-${LETHE_SESSION_ID:-${FALLBACK_SID}}}"

# project_id for Lethe API
PROJECT_ID="default"

CMD="${1:-}"
MSG="${2:-}"

if [ -z "$CMD" ] || [ -z "$MSG" ]; then
  echo "Usage: lethe-log <record|log|flag|task> <message> [options]" >&2
  echo "" >&2
  echo "Commands:" >&2
  echo "  record <msg>   Record a decision or conclusion" >&2
  echo "  log <msg>      Log an observation or finding" >&2
  echo "  flag <msg>     Flag uncertainty for human review" >&2
  echo "  task <msg>     Create or update a task" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  --confidence 0.9   Confidence score (0.0-1.0)" >&2
  echo "  --tags tag1,tag2   Comma-separated tags" >&2
  echo "  --status todo      Task status (todo|in_progress|done|blocked)" >&2
  echo "  --task-id ID       Update existing task by event ID" >&2
  exit 1
fi

# Parse options
CONFIDENCE="0.8"
TAGS=""
STATUS=""
TASK_ID=""

shift 2
while [ $# -gt 0 ]; do
  case "$1" in
    --confidence) CONFIDENCE="$2"; shift 2 ;;
    --tags) TAGS="$2"; shift 2 ;;
    --status) STATUS="$2"; shift 2 ;;
    --task-id) TASK_ID="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# Build tags JSON array
if [ -n "$TAGS" ]; then
  # Split on comma, filter empty
  TAGS_JSON="["
  first=true
  IFS=',' read -ra TAG_ARRAY <<< "$TAGS"
  for tag in "${TAG_ARRAY[@]}"; do
    tag=$(echo "$tag" | tr -d '[:space:]')
    if [ -n "$tag" ]; then
      if [ "$first" = true ]; then
        first=false
      else
        TAGS_JSON="$TAGS_JSON,"
      fi
      TAGS_JSON="$TAGS_JSON\"$tag\""
    fi
  done
  TAGS_JSON="$TAGS_JSON]"
else
  TAGS_JSON="[]"
fi

post_event() {
  local payload="$1"
  curl -s -X POST "${API}/api/events" \
    -H "Content-Type: application/json" \
    -d "$payload"
}

update_event() {
  local event_id="$1"
  local payload="$2"
  curl -s -X PUT "${API}/api/sessions/${SESSION_ID}/events/${event_id}" \
    -H "Content-Type: application/json" \
    -d "$payload"
}

if [ "$CMD" = "task" ]; then
  STATUS="${STATUS:-todo}"
  
  if [ -n "$TASK_ID" ]; then
    PAYLOAD=$(jq -n \
      --arg stat "$STATUS" \
      '{task_status: $stat}')
    RESULT=$(update_event "$TASK_ID" "$PAYLOAD")
    echo "Task updated: $RESULT"
  else
    PAYLOAD=$(jq -n \
      --arg sid "$SESSION_ID" \
      --arg pid "$PROJECT_ID" \
      --arg content "$MSG" \
      --arg stat "$STATUS" \
      --argjson conf "$CONFIDENCE" \
      --argjson tags "$TAGS_JSON" \
      '{
        session_id: $sid,
        project_id: $pid,
        event_type: "task",
        content: $content,
        confidence: $conf,
        tags: $tags,
        task_title: $content,
        task_status: $stat
      }')
    RESULT=$(post_event "$PAYLOAD")
    EVENT_ID=$(echo "$RESULT" | jq -r '.event_id' 2>/dev/null)
    if [ -n "$EVENT_ID" ] && [ "$EVENT_ID" != "null" ]; then
      echo "Task created: $EVENT_ID"
    else
      echo "Error: $RESULT" >&2
      exit 1
    fi
  fi
else
  PAYLOAD=$(jq -n \
    --arg sid "$SESSION_ID" \
    --arg pid "$PROJECT_ID" \
    --arg type "$CMD" \
    --arg content "$MSG" \
    --argjson conf "$CONFIDENCE" \
    --argjson tags "$TAGS_JSON" \
    '{
      session_id: $sid,
      project_id: $pid,
      event_type: $type,
      content: $content,
      confidence: $conf,
      tags: $tags
    }')
  
  RESULT=$(post_event "$PAYLOAD")
  EVENT_ID=$(echo "$RESULT" | jq -r '.event_id' 2>/dev/null)
  
  if [ -n "$EVENT_ID" ] && [ "$EVENT_ID" != "null" ]; then
    echo "OK ($EVENT_ID): $MSG"
  else
    echo "Error: $RESULT" >&2
    exit 1
  fi
fi
