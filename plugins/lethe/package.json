{
  "name": "@mentholmike/lethe",
  "version": "0.4.0",
  "description": "Lethe — persistent memory layer for AI agents. OpenClaw plugin.",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "files": [
    "index.js",
    "tools.js",
    "context-engine.js",
    "context-engine-types.js",
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "skills",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": "2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1"
    },
    "extensions": [
      "./index.js"
    ]
  },
  "scripts": {
    "build": "echo \"using committed dist bundle\"",
    "test": "node --test *.test.js",
    "clean": "echo \"committed dist bundle is kept\""
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "^0.70.0",
    "openclaw": ">=2026.7.1"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.70.0",
    "@types/node": "^20.0.0",
    "openclaw": "2026.7.1",
    "typescript": "^5.4.0",
    "tsc-alias": "^1.8.0"
  }
}
