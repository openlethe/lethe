# Lethe Configuration
# Copy this file to .env and edit, or use as-is for local trusted mode.

# API Key (required for non-localhost / non-private-network access)
# Generate with: openssl rand -hex 32
# LETHE_API_KEY=***

# Trust mode when no API key is set:
# - private: allows loopback + private networks (default)
# - loopback: allows only localhost
# LETHE_TRUST=private

# HTTP listen address inside container (usually leave as 0.0.0.0:18483)
# LETHE_HTTP=0.0.0.0:18483

# Data directory on host (must be writable by UID/GID 1000)
LETHE_DATA_DIR=./lethe-data
