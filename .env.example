# OpenLethe Configuration
# Copy this file to .env and edit, or use as-is for local trusted mode.
# This file preserves the original session/event memory service. Use
# docs/local-memory-git.md with docker-compose.git.yml for the isolated Memory Git service.

# API Key (required for non-localhost / non-private-network access)
# Generate with: openssl rand -hex 32
# LETHE_API_KEY=***

# API surface. The installed/local OpenLethe default is legacy.
# LETHE_MODE=legacy

# Charon merge-signing HMAC key (required only for hybrid migration deployments).
# Use the same CHARON_MERGE_HMAC_KEY configured on the trusted Charon service.
# (Legacy name CHARON_HMAC_KEY is still accepted as a fallback.)
# Generate with: openssl rand -hex 32
# CHARON_MERGE_HMAC_KEY=***

# Trust mode when no API key is set:
# - loopback: allows only localhost (default; safe for production)
# - private: allows loopback + private networks (treats locality as access)
# LETHE_TRUST=loopback

# Non-loopback binds (including 0.0.0.0) REQUIRE LETHE_API_KEY at startup.
# LETHE_ALLOW_INSECURE_BIND=1 bypasses the check (development-only, logged).

# Merge authorization keys with rotation overlap (preferred over the single
# key above): comma-separated keyid=secret pairs (each secret 32+ chars).
# CHARON_MERGE_HMAC_KEYS=v1=***,v2=***

# SQLite durability (all verified at startup; storage must honor fsync):
# LETHE_SQLITE_SYNCHRONOUS=FULL
# LETHE_SQLITE_BUSY_TIMEOUT_MS=5000
# LETHE_SQLITE_AUTOCHECKPOINT=1000

# Historical graph/reconstruction node cap before fail-closed error:
# LETHE_MEMORY_GIT_MAX_HISTORY=100000

# Recovery: block all mutations after a restore until reconciliation passes.
# LETHE_RECOVERY_READONLY=false

# HTTP listen address inside container (usually leave as 0.0.0.0:18483)
# LETHE_HTTP=0.0.0.0:18483

# Data directory on host (must be writable by UID/GID 1000)
LETHE_DATA_DIR=./lethe-data
