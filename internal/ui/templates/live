<div style="margin-bottom:24px">
  <h1 style="font-size:20px;font-weight:700;color:var(--text);margin-bottom:4px;">Live Session</h1>
  <p style="font-size:13px;color:var(--muted);">Real-time event stream</p>
</div>

<div class="card" style="margin-bottom:16px">
  <div class="card-header">
    <span class="card-title">Live Events</span>
    <button class="btn btn-ghost"
      hx-post="/api/sessions/agent%3Amain%3Adiscord%3Achannel%3A1480670530565574749/heartbeat"
      hx-swap="none"
      style="font-size:11px;padding:4px 10px;">
      Ping
    </button>
  </div>
  <div id="live-events"
    hx-get="/ui/session/agent%3Amain%3Adiscord%3Achannel%3A1480670530565574749/events-data"
    hx-trigger="load, every 3s"
    hx-swap="innerHTML">
    <div class="empty-state">Connecting…</div>
  </div>
</div>
