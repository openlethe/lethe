<div>
  {{range .threads}}
  <div style="padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px;">
    <div style="display:flex;align-items:center;gap:10px;">
      {{if eq (index . "status") "open"}}<span style="font-size:14px;">🔓</span>
      {{else if eq (index . "status") "resolved"}}<span style="font-size:14px;">✅</span>
      {{else}}<span style="font-size:14px;">🔴</span>{{end}}
      <div>
        <div style="font-size:13px;font-weight:600;color:var(--text);">{{index . "title"}}</div>
        <div style="font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:2px;">
          {{index . "name"}} · updated {{index . "updated_at" | since}} ago
        </div>
      </div>
    </div>
    <a href="/ui/threads/{{index . "thread_id"}}" style="font-size:12px;color:var(--accent);flex-shrink:0;">View →</a>
  </div>
  {{end}}
  {{if not .threads}}
  <div class="empty-state" style="padding:24px;text-align:center;color:var(--muted);font-size:13px;">
    <div style="font-size:20px;margin-bottom:6px;">🧵</div>
    <div>No open threads</div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px;">Flag something to create a thread</div>
  </div>
  {{end}}
</div>
